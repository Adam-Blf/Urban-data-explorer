          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/datamarts/arrondissements",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "datamarts",
            "arrondissements"
          ]
        }
      }
    },
